.DS_Store
*.log
node_modules/
dist/
coverage/

# Env files — .env* is ignored except the tracked template
.env
.env.*
!.env.example

# Local secret staging — real values live in Parameter Store / macOS Keychain,
# never in git. See docs/secrets.md.
*.secret.txt
.web-application-client-secret.txt
.places-api-key.txt

# CDK
infra/cdk.out/

# Evals: reports are generated; baselines are committed explicitly
evals/reports/*
!evals/reports/baseline*/
# Evals: local review aid (embeds images), regenerated on demand
evals/real-dataset-review.html

# Full-res source captures for the real eval set — the processed image.jpg in
# each evals/dataset/real/<case>/ is the committed copy; originals stay local.
images/

# iOS: project is generated from project.yml by XcodeGen
ios/*.xcodeproj
ios/DerivedData/
ios/.build/

# Playwright
test-results/
