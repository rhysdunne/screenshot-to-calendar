.DS_Store
*.log
node_modules/
dist/
coverage/

# Env files — .env* is ignored except the tracked template
.env
.env.*
!.env.example

# Local secret staging — real values live in Parameter Store / macOS Keychain,
# never in git. See docs/secrets.md.
*.secret.txt
.web-application-client-secret.txt
.places-api-key.txt

# CDK
infra/cdk.out/

# Evals: reports are generated; baselines are committed explicitly
evals/reports/*
!evals/reports/baseline*/
# Evals: local review aid (embeds images), regenerated on demand
evals/real-dataset-review.html

# Full-res source captures for the real eval set — the processed image.jpg in
# each evals/dataset/real/<case>/ is the committed copy; originals stay local.
images/

# iOS: project is generated from project.yml by XcodeGen. One exception is
# tracked inside it: the SPM lockfile, because Xcode Cloud disables automatic
# package resolution and refuses to build without a committed Package.resolved.
# (gitignore can't re-include a file inside an ignored directory, hence the
# unignore-dir/ignore-contents ladder.)
ios/*.xcodeproj/*
!ios/Screenshot2Cal.xcodeproj/project.xcworkspace/
ios/Screenshot2Cal.xcodeproj/project.xcworkspace/*
!ios/Screenshot2Cal.xcodeproj/project.xcworkspace/xcshareddata/
ios/Screenshot2Cal.xcodeproj/project.xcworkspace/xcshareddata/*
!ios/Screenshot2Cal.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
ios/Screenshot2Cal.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!ios/Screenshot2Cal.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
ios/DerivedData/
ios/.build/
ios/build/
# Info.plist and entitlements are generated from project.yml (properties inline)
ios/App/Info.plist
ios/App/App.entitlements
ios/ShareExtension/Info.plist
ios/ShareExtension/ShareExtension.entitlements

# Playwright
test-results/
.superpowers/
