# Local development environment variables.
# Copy to `.env` (gitignored) and fill in — do NOT put real values in this file.
#
# The app's RUNTIME secrets are NOT here: they're AWS Systems Manager Parameter
# Store SecureStrings under /s2c/{stage}/… (see docs/secrets.md). AWS credentials
# come from `aws configure` / SSO, not this file.

# Anthropic API key — the only secret local tooling needs.
# Used by `evals` (npm run eval) and `tools/prompt-improvement` (npm run gate).
# Get one at https://console.anthropic.com/, or load it from the macOS Keychain:
#   eval "$(scripts/secrets.sh env staging)"
ANTHROPIC_API_KEY=
