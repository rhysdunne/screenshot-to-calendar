# Tailscale (or other) hostname n8n is reachable at — used by docker-compose as WEBHOOK_URL
N8N_WEBHOOK_URL=http://YOUR_HOST:5678/

# n8n API credentials — used by `make pull` and `make push`
# Generate at: n8n Settings → API → Create API Key
N8N_API_KEY=your_n8n_api_key
# Find in the n8n editor URL: /workflow/{id}
N8N_WORKFLOW_ID=your_workflow_id
